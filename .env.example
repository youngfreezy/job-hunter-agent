# LLM provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-xxx
# Optional fallback if you explicitly set LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Database
DATABASE_URL=postgresql://user:pass@host:5432/db
NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxx

# Redis
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# Auth
NEXTAUTH_SECRET=xxx
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
ENABLE_CREDENTIALS_AUTH=false

# Inngest
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# Email
RESEND_API_KEY=re_xxx

# Geo
MAXMIND_LICENSE_KEY=xxx

# Sentry
SENTRY_DSN=https://xxx@sentry.io/xxx

# Proxy (for anti-detection)
PROXY_URL=http://user:pass@proxy-host:22225

# Browser settings
BROWSER_HEADLESS=false   # true = no visible browser windows (better for accessibility/CI)
BROWSER_SLOW_MO=0        # ms delay between Playwright actions (e.g. 100 for smoother headed mode)
BROWSER_MODE=cdp         # cdp = real Chrome, patchright = bundled Chromium

# Serper (Google Search API for job discovery)
SERPER_API_KEY=xxx
